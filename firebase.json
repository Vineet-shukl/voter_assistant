{
  "hosting": {
    "public": "static",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control",           "value": "public, max-age=3600" },
          { "key": "X-Frame-Options",         "value": "DENY" },
          { "key": "X-Content-Type-Options",  "value": "nosniff" },
          { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/chat",        "function": "chat",        "region": "asia-south1" },
      { "source": "/eligibility", "function": "eligibility", "region": "asia-south1" },
      { "source": "/timeline",    "function": "timeline",    "region": "asia-south1" },
      { "source": "/states",      "function": "states",      "region": "asia-south1" },
      { "source": "/health",      "function": "health",      "region": "asia-south1" },
      { "source": "**",           "destination": "/index.html" }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "asia-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "python311",
      "ignore": [
        "venv",
        ".venv",
        "**/__pycache__/**",
        "**/.pytest_cache/**"
      ]
    }
  ],
  "auth": {
    "providers": {
      "anonymous": true
    }
  }
}
