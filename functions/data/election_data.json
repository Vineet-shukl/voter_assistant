  "general_faqs": [
    {
      "question": "What is the Voter ID card called in India?",
      "answer": "The Voter ID card in India is officially called the EPIC — Electors Photo Identity Card. It is issued by the Election Commission of India."
    },
    {
      "question": "What if I don't have my Voter ID on election day?",
      "answer": "The ECI allows 12 alternative identity documents at polling booths including Aadhaar, Passport, Driving License, PAN Card, MNREGA Job Card, and Bank Passbook with photo."
    },
    {
      "question": "How do I register as a new voter?",
      "answer": "Fill Form 6 online at voters.eci.gov.in or visit your nearest BLO (Booth Level Officer). You must be 18+ and an Indian citizen."
    }
  ]
}
